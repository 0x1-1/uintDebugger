<ui version="4.0">
 <class>qtDLGMemorySearchClass</class>
 <widget class="QWidget" name="qtDLGMemorySearchClass">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>800</width>
    <height>540</height>
   </rect>
  </property>
  <property name="sizePolicy">
   <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
    <horstretch>0</horstretch>
    <verstretch>0</verstretch>
   </sizepolicy>
  </property>
  <property name="windowTitle">
   <string>[ uintDebugger ] - Memory Search</string>
  </property>
  <widget class="QWidget" name="verticalLayoutWidget">
   <property name="geometry">
    <rect>
     <x>0</x>
     <y>0</y>
     <width>800</width>
     <height>540</height>
    </rect>
   </property>
   <layout class="QVBoxLayout" name="mainLayout">
    <property name="margin">
     <number>6</number>
    </property>
    <property name="spacing">
     <number>4</number>
    </property>
    <item>
     <layout class="QHBoxLayout" name="searchBarLayout">
      <property name="spacing">
       <number>4</number>
      </property>
      <item>
       <widget class="QComboBox" name="cbSearchType">
        <property name="minimumWidth">
         <number>130</number>
        </property>
        <item>
         <property name="text">
          <string>Hex Bytes</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>ASCII String</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>Unicode String</string>
         </property>
        </item>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="lePattern">
        <property name="placeholderText">
         <string>Pattern (e.g. 48 8B ?? 00)</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnSearch">
        <property name="minimumWidth">
         <number>80</number>
        </property>
        <property name="text">
         <string>Search</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnClear">
        <property name="minimumWidth">
         <number>60</number>
        </property>
        <property name="text">
         <string>Clear</string>
        </property>
       </widget>
      </item>
     </layout>
    </item>
    <item>
     <layout class="QHBoxLayout" name="rangeLayout">
      <property name="spacing">
       <number>4</number>
      </property>
      <item>
       <widget class="QLabel" name="lblFrom">
        <property name="text">
         <string>From:</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="leStartAddr">
        <property name="maximumWidth">
         <number>160</number>
        </property>
        <property name="placeholderText">
         <string>0x0 (optional)</string>
